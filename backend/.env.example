# Backend environment variables
# Commit this file to GitHub. Put the real values only in local `.env`
# or in Vercel Project Settings -> Environment Variables.

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/rescueai
JWT_SECRET=replace-with-a-long-random-secret
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLIENT_URL=http://localhost:5173,http://localhost:5174,https://your-frontend.vercel.app
PORT=5000
