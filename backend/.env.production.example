# Backend production environment example for Vercel
# Commit this file to GitHub. Set the real values only in Vercel.

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/rescueai
JWT_SECRET=replace-with-a-long-random-secret
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLIENT_URL=https://your-frontend.vercel.app,https://your-frontend-git-main-your-team.vercel.app
